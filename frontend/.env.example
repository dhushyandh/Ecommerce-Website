# Frontend environment variable example for Create React App
# Variables must start with REACT_APP_ to be inlined at build time
REACT_APP_API_URL=https://vipstore-ecom.onrender.com/
REACT_APP_FRONTEND_URL=https://vipstore-ecom-157k.onrender.com/
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXX
REACT_APP_MAPBOX_TOKEN=your_mapbox_token
REACT_APP_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
REACT_APP_FEATURE_FLAG_X=false
